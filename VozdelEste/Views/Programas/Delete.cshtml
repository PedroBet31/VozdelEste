@model VozdelEste.Models.Programas

@{
    ViewBag.Title = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link href="~/Styles/Views/ProgramasViews.css" rel="stylesheet" />
}

<div class="perfil-panel">
    <h2>Confirmar Eliminación</h2>

    <p>¿Estás seguro que deseas eliminar el siguiente programa?</p>

    <dl class="perfil-info mb-4">
        <dt>Nombre</dt>
        <dd>@Model.Nombre</dd>

        @if (!string.IsNullOrEmpty(Model.Imagen))
        {
            <dt>Imagen</dt>
            <dd>
                <img src="@Model.Imagen" alt="Imagen" class="img-fluid rounded shadow" style="max-width: 400px; max-height: 250px; object-fit: contain;" />
                <br />
            </dd>
        }

        <dt>Descripción</dt>
        <dd>@Model.Descripcion</dd>

        <dt>Día</dt>
        <dd>@Model.DiaSemana</dd>

        <dt>Hora Inicio</dt>
        <dd>@Model.HoraInicio</dd>

        <dt>Hora Fin</dt>
        <dd>@Model.HoraFin</dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <div class="perfil-actions">
            <input type="submit" value="Eliminar" class="btn btn-eliminar" />
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-editar" })
        </div>
    }
</div>
