@model VozdelEste.Models.Conductores

@{
    ViewBag.Title = "Eliminar Conductor";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link href="~/Styles/Views/ConductoresViews.css" rel="stylesheet" />
}


<div class="perfil-panel">
    <h2>¿Eliminar este Conductor?</h2>

    @if (!string.IsNullOrEmpty(Model.Imagen))
    {
        <p><strong>Imagen:</strong></p>
        <img src="@Model.Imagen" alt="Foto conductor" style="max-width:100%; border-radius:10px; box-shadow:0 2px 6px rgba(0,0,0,0.4);" />
    }

    <div class="perfil-info mb-4">
        <p><strong>Nombre:</strong> @Model.Nombre</p>
        <p><strong>Biografía:</strong> @Model.Bio</p>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="perfil-actions">
            <input type="submit" value="Eliminar" class="btn btn-eliminar" />
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-editar" })
        </div>
    }
</div>
