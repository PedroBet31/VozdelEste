@{
    ViewBag.Title = "Cotizaciones";
}

<style>
    .tabla-cotizaciones {
        background-color: rgba(255,255,255,0.05);
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.5);
    }

        .tabla-cotizaciones table {
            color: #fff;
            background-color: transparent;
        }

        .tabla-cotizaciones th,
        .tabla-cotizaciones td {
            vertical-align: middle;
        }

        .tabla-cotizaciones a.btn {
            padding: 4px 10px;
        }
</style>

<h2 class="text-center text-light mb-4">Cotizaciones del día</h2>

<div class="container tabla-cotizaciones">
    <table class="table table-hover text-center">
        <thead>
            <tr class="table-secondary">
                <th>Moneda</th>
                <th>Valor</th>
                <th>Historial</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Dólar (USD)</td>
                <td>$@ViewBag.USD</td>
                <td><a class="btn btn-outline-info btn-sm" href="@Url.Action("Historial", "Home", new { moneda = "USD" })">Ver gráfico</a></td>
            </tr>
            <tr>
                <td>Euro (EUR)</td>
                <td>€@ViewBag.EUR</td>
                <td><a class="btn btn-outline-info btn-sm" href="@Url.Action("Historial", "Home", new { moneda = "EUR" })">Ver gráfico</a></td>
            </tr>
            <tr>
                <td>Real (BRL)</td>
                <td>R$@ViewBag.BRL</td>
                <td><a class="btn btn-outline-info btn-sm" href="@Url.Action("Historial", "Home", new { moneda = "BRL" })">Ver gráfico</a></td>
            </tr>
        </tbody>
    </table>
</div>
