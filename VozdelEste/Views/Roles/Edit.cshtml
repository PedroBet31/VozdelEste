@model VozdelEste.Models.EditarRolViewModel

@{
    ViewBag.Title = "Editar Rol";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link href="~/Styles/Views/RolesViews.css" rel="stylesheet" />
}

<div class="perfil-panel">
    <h2>Editar Rol</h2>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="mb-3">
            @Html.LabelFor(m => m.Nombre)
            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control" })
        </div>

        <h4 class="mt-4">Permisos</h4>
        <div class="mb-3">
            @for (int i = 0; i < Model.PermisosDisponibles.Count; i++)
            {
                <div class="form-check mb-2">
                    @Html.HiddenFor(m => m.PermisosDisponibles[i].Id)
                    <label class="form-check-label">
                        @Html.CheckBoxFor(m => m.PermisosDisponibles[i].Seleccionado, new { @class = "form-check-input" })
                        @Model.PermisosDisponibles[i].Nombre
                    </label>
                </div>
            }
        </div>

        <div class="perfil-actions">
            <button type="submit" class="btn btn-editar">Guardar</button>
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-eliminar" })
        </div>
    }
</div>
