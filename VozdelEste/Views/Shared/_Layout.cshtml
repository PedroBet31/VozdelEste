<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Voz del Este - @ViewBag.Title</title>
    <link rel="icon" type="image/png" href="~/Images/LOGO CHICO.png" />
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    @RenderSection("Styles", required: false)

    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <link href="~/Styles/Layout.css" rel="stylesheet" />

</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <img src="~/Images/LOGO PRINCIPAL.png" alt="Logo" width="90" height="64"
                     class="d-inline-block align-text-top"
                     style="box-shadow: 0 2px 6px rgba(0, 0, 0, 0.5); border-radius: 4px;" />
            </a>
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                    title="Alternar navegación" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation" style="border-color: #a3cef1;">
                <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
            </button>

            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                @{
                    var usuario = Session["Usuario"] as VozdelEste.Models.Usuarios;
                    bool esAdmin = usuario != null && usuario.Roles.Nombre == "Administrador";
                }

                <ul class="navbar-nav flex-grow-1 justify-content-end">

                    @if (!esAdmin)
                    {
                        <li class="nav-item">@Html.ActionLink("Noticias", "Index", "Noticias", null, new { @class = "nav-link" })</li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-toggle="dropdown">Programas</a>
                            <div class="dropdown-menu bg-dark border-0">
                                <a class="dropdown-item text-white" href="@Url.Action("Index", "Programas")">Listado</a>
                                <a class="dropdown-item text-white" href="@Url.Action("Index", "Calendario")">Calendario</a>
                            </div>
                        </li>   


                        <li class="nav-item">@Html.ActionLink("Conductores", "Index", "Conductores", null, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Patrocinadores", "Index", "Patrocinadores", null, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Contacto", "Contact", "Home", null, new { @class = "nav-link" })</li>
                    }

                    @if (esAdmin)
                    {
                        <li class="nav-item">@Html.ActionLink("Dashboard", "Index", "Dashboard", null, new { @class = "nav-link" })</li>
                    }

                    @if (usuario == null)
                    {
                        <li class="nav-item">@Html.ActionLink("Login", "Login", "Usuarios", null, new { @class = "nav-link" })</li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" href="@Url.Action("Perfil", "Usuarios")">
                                Hola, @usuario.Nombre
                            </a>
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Cerrar sesión", "Logout", "Usuarios", null, new { @class = "nav-link" })
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container body-content">
        @RenderBody()
        <hr />
    </div>
    <footer>
        @Html.Action("Reproductor", "Home")
    </footer>
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)


</body>
</html>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
