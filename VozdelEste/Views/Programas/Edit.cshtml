@model VozdelEste.Models.Programas

@{
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link href="~/Styles/Views/ProgramasViews.css" rel="stylesheet" />
}

<div class="perfil-panel">
    <h2>Editar Programa</h2>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.Id)
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="mb-3">
            @Html.LabelFor(model => model.Nombre)
            @Html.TextBoxFor(model => model.Nombre, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            @if (!string.IsNullOrEmpty(Model.Imagen))
            {
                <dt>Imagen</dt>
                <dd>
                    <img src="@Model.Imagen" alt="Imagen" class="img-fluid rounded shadow" style="max-width: 400px; max-height: 250px; object-fit: contain;" />
                    <br />
                </dd>
            }
            @Html.LabelFor(model => model.Imagen)
            @Html.TextBoxFor(model => model.Imagen, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(model => model.Descripcion)
            @Html.TextAreaFor(model => model.Descripcion, new { @class = "form-control", rows = 4 })
        </div>

        <div class="mb-3">
            @Html.LabelFor(model => model.DiaSemana)
            @Html.TextBoxFor(model => model.DiaSemana, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(model => model.HoraInicio)
            @Html.TextBoxFor(model => model.HoraInicio, new { @class = "form-control", type = "time" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(model => model.HoraFin)
            @Html.TextBoxFor(model => model.HoraFin, new { @class = "form-control", type = "time" })
        </div>

        <div class="perfil-actions">
            <input type="submit" value="Guardar" class="btn btn-editar" />
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-eliminar" })
        </div>
    }
</div>
